# Server
PORT=8080
ENV=development
BASE_URL=http://localhost:8080

# PostgreSQL
DATABASE_URL=postgres://festival:festival_secret@localhost:5432/festival_db?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Payment provider: mock, helloasso, lydia
PAYMENT_PROVIDER=mock

# HelloAsso API v5 (only needed when PAYMENT_PROVIDER=helloasso)
HELLOASSO_CLIENT_ID=your_client_id
HELLOASSO_CLIENT_SECRET=your_client_secret
HELLOASSO_ORG_SLUG=your_organization_slug
HELLOASSO_API_URL=https://api.helloasso.com
# HELLOASSO_RETURN_URL and HELLOASSO_ERROR_URL default to BASE_URL if not specified

# Lydia API (only needed when PAYMENT_PROVIDER=lydia)
LYDIA_API_URL=https://homologation.lydia-app.com
LYDIA_VENDOR_TOKEN=
LYDIA_VENDOR_PRIVATE_TOKEN=
# Leave empty to let Lydia choose the default collect/method for your account.
# Set explicitly only if your homologation account supports it (e.g. cb).
LYDIA_PAYMENT_METHOD=
LYDIA_DEBUG=false

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_key

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=festival@yourfestival.com
SMTP_FROM_NAME=L'Interfilières

# Ticket PDF generation
# auto: try wkhtmltopdf then fallback to fpdf
# wkhtmltopdf: require wkhtmltopdf binary
# fpdf: legacy basic renderer (limited HTML/CSS)
TICKET_PDF_ENGINE=auto
WKHTMLTOPDF_BIN=wkhtmltopdf
TICKET_PDF_TEMPLATE_PATH=mail/ticket_pdf.html

# Festival
FESTIVAL_NAME=L'Interfilières
FESTIVAL_DATE=2026-07-15
